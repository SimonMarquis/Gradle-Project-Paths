<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>gradle-project-paths</id>
    <name>Gradle Project Paths</name>
    <vendor url="https://github.com/SimonMarquis/Gradle-Project-Paths">Simon Marquis</vendor>
    <description><![CDATA[
        <p>
          An IntelliJ plugin that helps autocomplete Gradle project paths.<br>
          For those of us who'd rather avoid <code>enableFeaturePreview("TYPESAFE_PROJECT_ACCESSORS")</code>.
        </p>
        <ul>
          <li><b>Autocompletion</b>: suggests all Gradle project paths inside <code>project("...")</code> calls
          <li><b>Validation</b>: detect and highlights unknown Gradle project paths
          <li><b>Navigation</b> gutter icons or <kbd>Ctrl</kbd>+<kbd>click</kbd> on Gradle project paths to jump to its Gradle build file
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.gradle</depends>
    <depends>org.jetbrains.kotlin</depends>

    <resource-bundle>messages.GradleProjectPathsBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <annotator language="kotlin"
                   implementationClass="fr.smarquis.intellij.gpp.GradleProjectPathsAnnotator"/>
        <codeInsight.lineMarkerProvider language="kotlin"
                                        implementationClass="fr.smarquis.intellij.gpp.GradleProjectPathsLineMarkerProvider"/>
        <completion.contributor language="kotlin"
                                id="gradleProjectPathsKotlin"
                                implementationClass="fr.smarquis.intellij.gpp.GradleProjectPathsCompletionContributor"
                                order="first, before KotlinCompletionContributor, before default"/>
        <psi.referenceContributor language="kotlin"
                                  implementation="fr.smarquis.intellij.gpp.GradleProjectReferenceContributor"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <actions>
        <action id="fr.smarquis.intellij.gpp.GradleProjectPathsRefreshAction"
                class="fr.smarquis.intellij.gpp.GradleProjectPathsRefreshAction"
                icon="GradleIcons.GradleLoadChanges">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

    </actions>
</idea-plugin>
